{
  "specs": [
    {
      "schema_version": "V1",
      "name": "app",
      "image": {
        "registry": "ghcr.io",
        "repository": "example/app",
        "tag": "dev",
        "digest": "sha256:abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd"
      },
      "tier": "private",
      "replicas": 1,
      "resources": { "memory_mb": 256, "cpu_shares": 512, "ephemeral_storage_mb": 512 },
      "restart_policy": { "type": "always" },
      "stop_policy": { "signal": 15, "grace_period": 10000 },
      "expose": {
        "mesh": { "identity": "app", "ports": [8080] }
      }
    }
  ],
  "warnings": [
    {
      "path": "services.app.build",
      "message": "build: blocks are ignored. Build externally (CI) and provide an image: reference; see arch doc §\"What's deliberately not in the schema\""
    }
  ]
}
