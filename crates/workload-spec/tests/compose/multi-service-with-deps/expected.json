{
  "specs": [
    {
      "schema_version": "V1",
      "name": "api",
      "image": {
        "registry": "ghcr.io",
        "repository": "example/api",
        "tag": "v1",
        "digest": "sha256:abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd"
      },
      "tier": "private",
      "replicas": 1,
      "env": [
        { "name": "DATABASE_URL", "value": { "type": "literal", "value": "postgres://db:5432/app" } },
        { "name": "LOG_LEVEL", "value": { "type": "literal", "value": "debug" } }
      ],
      "resources": { "memory_mb": 256, "cpu_shares": 512, "ephemeral_storage_mb": 512 },
      "depends_on": ["db"],
      "restart_policy": { "type": "always" },
      "stop_policy": { "signal": 15, "grace_period": 10000 },
      "expose": {
        "mesh": { "identity": "api", "ports": [3000] }
      }
    },
    {
      "schema_version": "V1",
      "name": "db",
      "image": {
        "registry": "docker.io",
        "repository": "library/postgres",
        "tag": "15",
        "digest": "sha256:1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
      },
      "tier": "private",
      "replicas": 1,
      "env": [
        { "name": "POSTGRES_PASSWORD", "value": { "type": "literal", "value": "secret" } }
      ],
      "resources": { "memory_mb": 256, "cpu_shares": 512, "ephemeral_storage_mb": 512 },
      "restart_policy": { "type": "always" },
      "stop_policy": { "signal": 15, "grace_period": 10000 },
      "expose": {
        "mesh": { "identity": "db", "ports": [] }
      }
    }
  ]
}
